# CLIMAN LIVE — Cache control
# Hostinger / Apache / LiteSpeed compatible

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                "access plus 0 seconds"
  ExpiresByType text/css                 "access plus 1 hours"
  ExpiresByType application/javascript   "access plus 1 hours"
  ExpiresByType application/json         "access plus 1 hours"
  ExpiresByType image/webp               "access plus 1 month"
  ExpiresByType image/jpeg               "access plus 1 month"
  ExpiresByType image/png                "access plus 1 month"
  ExpiresByType image/svg+xml            "access plus 1 month"
  ExpiresByType font/woff2               "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(html|css|js|json)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(webp|jpg|jpeg|png|svg|woff|woff2)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  AddType image/webp          .webp
  AddType application/javascript .js
  AddType text/css            .css
</IfModule>
